# ── Build outputs (Makefile writes to bin/) ──────────
bin/

# Note: gormes/gormes (root-level binary) is intentionally tracked
# per the repo's existing 'refresh tracked binary' pattern. See
# commit b42ff8a6 if that policy needs revisiting.

# ── Go binaries for other platforms ──────────────────
*.exe
*.dll
*.so
*.dylib
*.a

# ── Go test / coverage / profile artifacts ───────────
*.test
*.out
coverage.out
coverage.html
*.prof
*.pprof

# ── Runtime logs and crash dumps ─────────────────────
gormes.log
crash-*.log

# ── Local state directories (when run in-repo) ───────
.gormes/
.hermes/
